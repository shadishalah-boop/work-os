{
  "_README": [
    "Custom Metrics-card definitions, pulled live from Looker and/or Snowflake on each /dashboard refresh.",
    "This file is the SINGLE source of truth for the Metrics card when present — it's what the dashboard's ✎ Edit button reads and writes (via the local server), and it takes precedence over the 'metrics' block in dashboard-config.local.",
    "COPY to ~/.claude/dashboard-metrics.local.json (note the .json) to hand-edit, or just use the on-dashboard editor.",
    "Each item: a label, a source ('looker' | 'snowflake'), exactly ONE reference for that source, and optional target/format.",
    "Values + the trend arrow fill on the next refresh — the browser can't query your warehouse; the refresh agent does."
  ],
  "items": [
    {
      "id": "m1",
      "label": "Weekly active learners",
      "source": "snowflake",
      "nl": "weekly active learners, this week vs last week",
      "format": "k",
      "target": "target 450k"
    },
    {
      "id": "m2",
      "label": "Avg revenue per user",
      "source": "snowflake",
      "sql": "SELECT arpu_current AS value, arpu_prior AS prev FROM analytics.kpis.arpu",
      "format": "plain",
      "target": "target $42"
    },
    {
      "id": "m3",
      "label": "Payment fees / GMV (Looker — optional, needs Looker MCP in Claude Code)",
      "source": "looker",
      "field": "fact_payment.payment_fees_over_gmv_proceeds",
      "format": "%",
      "target": "target < 2%"
    }
  ]
}
