{
  "_README": [
    "COPY this file to ~/.claude/dashboard-config.local and edit the values.",
    "The dashboard skill reads this on every refresh. Restart is not needed — edits apply on the next /dashboard run.",
    "All fields are optional; omit any you don't care about and sensible defaults will be used.",
    "timezone: keep it 'auto' to follow your computer's zone live on every refresh (great for travel). Set an IANA name like 'America/New_York' or 'Asia/Singapore' only to PIN a fixed zone.",
    "This file is NEVER bundled into a plugin share — it stays on your machine."
  ],

  "user": {
    "name": "Alex",
    "fullName": "Alex Rivera",
    "role": "Senior PM",
    "email": "alex@example.com",
    "avatar": "",
    "_avatar_note": "Optional. The browser-tab favicon uses your Slack profile photo automatically (fetched on each refresh). Set a direct image URL here only to override that.",
    "timezone": "auto",
    "workingHours": { "start": "09:00", "end": "18:30", "days": ["Mon", "Tue", "Wed", "Thu", "Fri"] }
  },

  "org": {
    "company": "Acme",
    "manager": {
      "name": "Morgan Chen",
      "email": "morgan@example.com",
      "role": "VP Product"
    },
    "seniorStakeholders": ["Sam", "Priya", "Theo", "Mia"],
    "team": {
      "attention": "Note surfaced in the Team module (HTML allowed, keep short).",
      "people": [
        { "name": "Morgan Chen",   "note": "Manager · VP Product",     "manager": true,  "ooo": false, "status": "active" },
        { "name": "Priya Shah",    "note": "Sr. PM · Growth",          "manager": false, "ooo": false, "status": "active" },
        { "name": "Theo Rodrigues","note": "Brand Lead",                "manager": false, "ooo": false, "status": "active" },
        { "name": "Mia Koleva",    "note": "Pricing Strategy",          "manager": false, "ooo": true,  "status": "active" }
      ]
    }
  },

  "slack": {
    "workspace": "acme",
    "userId": "",
    "highSignalChannels": ["#incident-*", "#proj-*", "#leadership"]
  },

  "mcp": {
    "_README": "Server names of your MCP connectors, as shown by /mcp. /dashboard-setup auto-detects and fills these. NOTE: claude.ai-managed connectors are often prefixed, e.g. 'claude_ai_Google_Calendar', 'claude_ai_Slack' — use the exact name from /mcp. The agents also fall back to a capability search if a name is wrong.",
    "calendar": "Google_Calendar",
    "gmail": "Gmail",
    "slack": "Slack",
    "drive": "Google_Drive",
    "granola": "Granola",
    "zoom": "Zoom_for_Claude",
    "looker": "Looker",
    "snowflake": "Snowflake"
  },

  "metrics": {
    "_README": [
      "OPTIONAL custom metrics for the Metrics card, pulled live from Looker and/or Snowflake.",
      "You can also add/edit/reorder these right on the dashboard (the ✎ Edit button on the Metrics card) — that writes ~/.claude/dashboard-metrics.local.json, which takes precedence over this block.",
      "Each metric needs a label, a source ('looker' or 'snowflake'), and ONE reference for that source. target/format are optional.",
      "format: '%' | 'k' | 'M' | 'h' | 'plain' (how to render the number). target: free text shown under the value (e.g. 'target 450k').",
      "Values + the trend arrow fill on the next /dashboard refresh — the browser can't call your data warehouse, the refresh agent does."
    ],
    "_recommended": "Snowflake is the zero-setup source: it's a connector you authorize once (like Slack/Gmail) and it works in-session. Looker via MCP is also supported, but it currently requires each person to wire the Looker MCP into Claude Code, so prefer Snowflake for anything you share with the team.",
    "items": [
      {
        "id": "m1", "label": "Weekly active learners", "source": "snowflake", "format": "k", "target": "target 450k",
        "sql": "SELECT wal_current AS value, wal_prior AS prev FROM analytics.kpis.weekly_active_learners",
        "_sql_note": "Return one row: a 'value' column (current) and an optional 'prev' column (prior period, for the ▲/▼ delta)."
      },
      {
        "id": "m2", "label": "Payment fees / GMV", "source": "looker", "format": "%", "target": "target < 2%",
        "field": "fact_payment.payment_fees_over_gmv_proceeds",
        "_field_note": "OPTIONAL — only works if you've added a Looker MCP to Claude Code. A LookML view.field measure the agent runs for the current vs prior period."
      }
    ],
    "_ref_types_README": [
      "snowflake reference (recommended, zero setup): 'sql' = a query returning a 'value' column (and optional 'prev' column).",
      "looker references (optional, needs the Looker MCP in Claude Code; use ONE): 'field' = LookML view.field measure | 'look' = a Look URL or ID | 'query' = plain-English | 'dashboard'+'tile' = a Looker dashboard tile."
    ]
  },

  "dashboard": {
    "workstreams": [
      "Pricing v3",
      "Onboarding v2",
      "Enterprise SSO",
      "Brand refresh"
    ],
    "classificationKeywords": ["pricing", "onboarding", "SSO", "brand", "Q2", "strategy"],

    "okrs": [
      { "id": "k1", "name": "Pricing v3 — ship by May 6",     "pct": 40, "trend": "on-pace", "short": "Pri", "keywords": ["pricing", "tier", "bundle"] },
      { "id": "k2", "name": "Onboarding v2 — 100% rollout",   "pct": 90, "trend": "on-pace", "short": "Onb", "keywords": ["onboarding", "activation"] },
      { "id": "k3", "name": "Enterprise SSO — design review", "pct": 25, "trend": "behind",  "short": "SSO", "keywords": ["sso", "enterprise", "auth"] }
    ],
    "_okrs_README": "okrs is optional (empty array = OKR section shows a setup hint). Per OKR: short = 2-4 char pill label (default K1, K2, …); keywords = lowercase substrings that auto-suggest tagging matching tasks/decisions to this OKR (omit for manual tagging only).",

    "pins": [
      { "id": "pn1", "label": "Q2 OKRs sheet",   "sub": "Sheets",       "letter": "O", "bg": "var(--teal-100)",   "href": "https://docs.google.com/spreadsheets/d/REPLACE/edit" },
      { "id": "pn2", "label": "Granola",         "sub": "Meeting notes","letter": "G", "bg": "var(--pink-100)",   "href": "https://app.granola.ai" },
      { "id": "pn3", "label": "Gmail",           "sub": "Inbox",        "letter": "M", "bg": "var(--red-100)",    "href": "https://mail.google.com/mail/u/0/#inbox" },
      { "id": "pn4", "label": "Google Calendar", "sub": "Week view",    "letter": "C", "bg": "var(--blue-100)",   "href": "https://calendar.google.com/calendar/u/0/r/week" },
      { "id": "pn5", "label": "Slack",           "sub": "Workspace",    "letter": "#", "bg": "var(--yellow-100)", "href": "https://acme.slack.com" },
      { "id": "pn6", "label": "Google Drive",    "sub": "Files",        "letter": "D", "bg": "var(--grey-100)",   "href": "https://drive.google.com" }
    ],

    "weather": { "city": "Barcelona" },

    "focusTarget": 4,

    "knownPeople": [
      { "match": "Morgan Chen", "name": "Morgan Chen", "note": "Manager · VP Product", "manager": true },
      { "match": "Priya Shah",  "name": "Priya Shah",  "note": "Sr. PM · Growth" },
      { "match": "Morgan",      "name": "Morgan Chen", "note": "Manager · VP Product", "manager": true },
      { "match": "Priya",       "name": "Priya Shah",  "note": "Sr. PM · Growth" }
    ],

    "pinnedPeople": [
      { "name": "Morgan Chen", "note": "Manager · VP Product",   "manager": true, "bg": "linear-gradient(135deg, #4a6cf7, #6e8bf5)" },
      { "name": "Priya Shah",  "note": "Sr. PM · Growth",                          "bg": "linear-gradient(135deg, #1abc9c, #2ed8b6)" },
      { "name": "Theo Rodrigues", "note": "Brand Lead",                            "bg": "linear-gradient(135deg, #f7a14a, #fcb96b)" }
    ]
  },

  "output": {
    "dashboardDir": "~/.claude/dashboard-os",
    "dataCacheDir": "~/.claude/dashboard-data"
  }
}
