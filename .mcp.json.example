{
  "_README": [
    "COPY this file to `.mcp.json` in your project root (or merge into ~/.claude.json) and fill in the command/args/env for each server.",
    "The 6 dashboard agents reference tools using these exact server names — keep the keys as-is or rename them alongside the agents.",
    "Each server below is a TEMPLATE. Replace the `command` + `args` with the actual MCP server you want to use for that integration.",
    "Auth credentials typically go in `env` or via OAuth flow. See each MCP server's README for details."
  ],
  "mcpServers": {
    "calendar": {
      "_hint": "Google Calendar MCP. e.g. https://github.com/nspady/google-calendar-mcp or similar",
      "command": "npx",
      "args": ["-y", "google-calendar-mcp@latest"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/absolute/path/to/credentials.json"
      }
    },
    "gmail": {
      "_hint": "Gmail MCP server (OAuth). e.g. https://github.com/GongRzhe/Gmail-MCP-Server or similar",
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"]
    },
    "slack": {
      "_hint": "Slack MCP. Requires Slack workspace token.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-...",
        "SLACK_TEAM_ID": "T..."
      }
    },
    "drive": {
      "_hint": "Google Drive MCP (OAuth).",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive"]
    },
    "granola": {
      "_hint": "Granola MCP — local app. See https://github.com/iamwavecut/granola-mcp",
      "command": "npx",
      "args": ["-y", "granola-mcp"]
    }
  }
}
